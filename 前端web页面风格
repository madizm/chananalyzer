<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>新拟态 · 侧边栏贴左 · 内容填满</title>
  <style>
    /* 基础重置：让布局占满全屏，无内外边距 */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', Roboto, system-ui, -apple-system, sans-serif;
    }

    html, body {
      height: 100%;
      background: #eef2f5;  /* 与新拟态背景色一致，使边缘过渡自然 */
    }

    body {
      /* 不再有 padding 或居中，dashboard 直接铺满 */
      overflow-x: hidden;    /* 防止阴影溢出产生横向滚动条（可选） */
    }

    /* 主容器：左右结构，占满全屏，列之间保留20px间隔 */
    .dashboard {
      width: 100%;
      height: 100%;
      display: flex;
      gap: 20px;             /* 侧边栏与内容区的间距 */
      padding: 0;            /* 关键：无内边距，使侧边栏左侧贴边，内容右侧贴边 */
    }

    /* 新拟态卡片基类 (凸起) */
    .neumorph-card {
      background: #eef2f5;
      box-shadow: 12px 12px 24px #c0c8d0, -12px -12px 24px #ffffff;
      border-radius: 48px;
      padding: 28px 20px;
      transition: box-shadow 0.2s ease;
    }

    /* 左侧边栏 */
    .sidebar {
      width: 280px;
      display: flex;
      flex-direction: column;
      height: 100%;          /* 撑满左侧高度 */
    }

    .sidebar-header {
      padding: 0 16px 20px 16px;
      border-bottom: 2px solid rgba(192, 200, 208, 0.3);
      margin-bottom: 24px;
    }

    .sidebar-header h2 {
      font-weight: 450;
      color: #3d4a5c;
      font-size: 1.8rem;
      letter-spacing: 0.5px;
      text-shadow: 2px 2px 4px #c0c8d0, -2px -2px 4px #ffffff;
    }

    .sidebar-header p {
      color: #607080;
      font-size: 0.9rem;
      margin-top: 6px;
    }

    /* 菜单列表 */
    .menu {
      display: flex;
      flex-direction: column;
      gap: 18px;
      flex: 1;
    }

    /* 新拟态菜单项 (按钮) */
    .menu-item {
      background: #eef2f5;
      box-shadow: 8px 8px 16px #c0c8d0, -8px -8px 16px #ffffff;
      border-radius: 100px;        /* 大圆角药丸形状 */
      padding: 16px 24px;
      border: none;
      font-size: 1.2rem;
      font-weight: 550;
      color: #3d4a5c;
      text-align: left;
      display: flex;
      align-items: center;
      gap: 16px;
      cursor: pointer;
      transition: all 0.15s ease;
      width: 100%;
    }

    .menu-item .icon {
      font-size: 1.7rem;
      filter: drop-shadow(2px 2px 4px rgba(0,0,0,0.1));
    }

    /* 激活状态的菜单 — 内凹效果 */
    .menu-item.active {
      box-shadow: inset 6px 6px 12px #c0c8d0, inset -6px -6px 12px #ffffff;
      color: #2b3b4e;
    }

    .menu-item:hover:not(.active) {
      box-shadow: 10px 10px 20px #b0b8c0, -10px -10px 20px #ffffff;
    }

    /* 右侧内容区域 — 自动填满剩余宽度 */
    .content-panel {
      flex: 1;               /* 关键：填满右侧剩余空间 */
      height: 100%;          /* 高度撑满 */
      display: flex;
      flex-direction: column;
    }

    /* 动态内容卡片 (带内凹阴影，增加层次) */
    .content-card {
      background: #eef2f5;
      box-shadow: inset 2px 2px 5px #c0c8d0, inset -2px -2px 5px #ffffff, 12px 12px 24px #c0c8d0, -12px -12px 24px #ffffff;
      border-radius: 42px;
      padding: 32px 36px;
      height: 100%;
      color: #3d4a5c;
    }

    .content-card h3 {
      font-size: 2.2rem;
      font-weight: 420;
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .content-card h3 span {
      font-size: 2.5rem;
    }

    .content-divider {
      height: 3px;
      background: linear-gradient(90deg, #b0c0d0, transparent);
      margin: 25px 0 30px 0;
      border-radius: 3px;
    }

    /* 指标卡片 */
    .analysis-placeholder {
      display: flex;
      flex-direction: column;
      gap: 28px;
    }

    .metric-row {
      display: flex;
      gap: 25px;
      flex-wrap: wrap;
    }

    .metric {
      flex: 1 1 160px;
      background: #eef2f5;
      box-shadow: 8px 8px 16px #c0c8d0, -8px -8px 16px #ffffff;
      border-radius: 32px;
      padding: 22px 16px;
      text-align: center;
    }

    .metric .value {
      font-size: 2.3rem;
      font-weight: 500;
      color: #1f2f3f;
    }

    .metric .label {
      font-size: 1rem;
      color: #607080;
      margin-top: 8px;
    }

    /* 图表占位 */
    .chart-placeholder {
      background: #eef2f5;
      box-shadow: inset 4px 4px 8px #c0c8d0, inset -4px -4px 8px #ffffff;
      border-radius: 38px;
      padding: 50px 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #7a8b9f;
      font-size: 1.3rem;
      letter-spacing: 1px;
      margin: 15px 0;
    }

    /* 板块列表 */
    .chip-list {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .chip-item {
      background: #eef2f5;
      box-shadow: 6px 6px 12px #c0c8d0, -6px -6px 12px #ffffff;
      border-radius: 50px;
      padding: 18px 25px;
      font-size: 1.2rem;
      display: flex;
      align-items: center;
      gap: 18px;
    }

    .chip-bullet {
      width: 14px;
      height: 14px;
      background: #6c7e9c;
      border-radius: 50%;
      box-shadow: inset 2px 2px 4px #2a3a4a, inset -2px -2px 4px #b0c0d0;
    }

    .hidden {
      display: none !important;
    }

    /* 小屏幕时改为上下堆叠 */
    @media (max-width: 850px) {
      .dashboard {
        flex-direction: column;
        height: auto;
        gap: 20px;
      }
      .sidebar {
        width: 100%;
        height: auto;
      }
      .content-panel {
        height: auto;
      }
    }
  </style>
</head>
<body>
  <div class="dashboard">
    <!-- 左侧边栏：紧贴浏览器左侧 -->
    <aside class="sidebar neumorph-card">
      <div class="sidebar-header">
        <h2>📊 股票分析</h2>
        <p>Neumorphism · 贴边布局</p>
      </div>
      <nav class="menu" id="menu">
        <button class="menu-item active" data-target="individual">
          <span class="icon">📈</span> 个股分析
        </button>
        <button class="menu-item" data-target="sector">
          <span class="icon">🗂️</span> 板块筛选
        </button>
        <button class="menu-item" data-target="trade">
          <span class="icon">⚡</span> 买卖点筛选
        </button>
        <button class="menu-item" data-target="kline">
          <span class="icon">📉</span> K线图表
        </button>
        <button class="menu-item" data-target="chan">
          <span class="icon">🧩</span> 缠论买卖点说明
        </button>
      </nav>
      <div style="margin-top: auto; padding: 16px; opacity: 0.6; font-size: 0.9rem;">
        ⚙️ 五维分析工具
      </div>
    </aside>

    <!-- 右侧内容区域：自动填满剩余宽度，紧贴右侧 -->
    <main class="content-panel neumorph-card">
      <!-- 个股分析 -->
      <div id="individual" class="content-card">
        <h3><span>📈</span> 个股分析</h3>
        <div class="content-divider"></div>
        <div class="analysis-placeholder">
          <div class="metric-row">
            <div class="metric">
              <div class="value">168.30</div>
              <div class="label">当前价格 (CNY)</div>
            </div>
            <div class="metric">
              <div class="value">+2.34%</div>
              <div class="label">涨幅</div>
            </div>
            <div class="metric">
              <div class="value">2.1亿</div>
              <div class="label">成交量</div>
            </div>
          </div>
          <div class="metric-row">
            <div class="metric">
              <div class="value">PE 25.6</div>
              <div class="label">市盈率</div>
            </div>
            <div class="metric">
              <div class="value">3.21</div>
              <div class="label">换手率%</div>
            </div>
            <div class="metric">
              <div class="value">86.5亿</div>
              <div class="label">流通市值</div>
            </div>
          </div>
          <div style="margin-top: 20px; color: #5a6b7c;">⚡ 均线多头排列，MACD金叉信号</div>
        </div>
      </div>

      <!-- 板块筛选 -->
      <div id="sector" class="content-card hidden">
        <h3><span>🗂️</span> 板块筛选</h3>
        <div class="content-divider"></div>
        <div class="chip-list">
          <div class="chip-item"><span class="chip-bullet"></span> 新能源 · 光伏 +3.2%</div>
          <div class="chip-item"><span class="chip-bullet"></span> 半导体 · 设备 +1.8%</div>
          <div class="chip-item"><span class="chip-bullet"></span> 创新药 · 生物 -0.4%</div>
          <div class="chip-item"><span class="chip-bullet"></span> 人工智能 · 算力 +4.1%</div>
          <div class="chip-item"><span class="chip-bullet"></span> 大消费 · 白酒 -1.2%</div>
        </div>
        <p style="margin-top: 32px;">🔥 热门板块：人工智能、低空经济</p>
      </div>

      <!-- 买卖点筛选 -->
      <div id="trade" class="content-card hidden">
        <h3><span>⚡</span> 买卖点筛选</h3>
        <div class="content-divider"></div>
        <div class="metric-row">
          <div class="metric">
            <div class="value">买 B</div>
            <div class="label">日线底分型</div>
          </div>
          <div class="metric">
            <div class="value">卖 S</div>
            <div class="label">顶背离信号</div>
          </div>
          <div class="metric">
            <div class="value">6</div>
            <div class="label">今日买点标的</div>
          </div>
        </div>
        <div class="chart-placeholder" style="margin-top: 30px;">
          ⏰ 筛选条件：MACD金叉 + 成交量放大
        </div>
      </div>

      <!-- K线图表 -->
      <div id="kline" class="content-card hidden">
        <h3><span>📉</span> K线图表</h3>
        <div class="content-divider"></div>
        <div class="chart-placeholder" style="padding: 80px 20px;">
          📊 日K 模拟图 (MA5, MA10, MA30)
        </div>
        <div class="metric-row" style="margin-top: 20px;">
          <div class="metric">开 168.2</div>
          <div class="metric">高 172.5</div>
          <div class="metric">低 167.8</div>
          <div class="metric">收 171.3</div>
        </div>
      </div>

      <!-- 缠论买卖点说明 -->
      <div id="chan" class="content-card hidden">
        <h3><span>🧩</span> 缠论买卖点说明</h3>
        <div class="content-divider"></div>
        <div class="chip-list">
          <div class="chip-item"><span class="chip-bullet"></span> 第一类买点：趋势背驰后</div>
          <div class="chip-item"><span class="chip-bullet"></span> 第二类买点：回调不创新低</div>
          <div class="chip-item"><span class="chip-bullet"></span> 第三类买点：突破中枢回踩</div>
          <div class="chip-item"><span class="chip-bullet"></span> 第一类卖点：趋势背驰后</div>
          <div class="chip-item"><span class="chip-bullet"></span> 第二类卖点：反弹不创新高</div>
        </div>
        <p style="margin-top: 28px;">📘 当前30分钟级别出现第二类买点迹象。</p>
      </div>
    </main>
  </div>

  <script>
    (function() {
      const menuButtons = document.querySelectorAll('.menu-item');
      const contentSections = {
        individual: document.getElementById('individual'),
        sector: document.getElementById('sector'),
        trade: document.getElementById('trade'),
        kline: document.getElementById('kline'),
        chan: document.getElementById('chan')
      };

      menuButtons.forEach(btn => {
        btn.addEventListener('click', function() {
          menuButtons.forEach(b => b.classList.remove('active'));
          this.classList.add('active');

          const targetId = this.getAttribute('data-target');
          Object.values(contentSections).forEach(section => {
            if (section) section.classList.add('hidden');
          });
          if (targetId && contentSections[targetId]) {
            contentSections[targetId].classList.remove('hidden');
          }
        });
      });

      // 确保初始状态正确
      const activeMenu = document.querySelector('.menu-item.active');
      if (activeMenu) {
        const defaultTarget = activeMenu.getAttribute('data-target');
        Object.values(contentSections).forEach(section => section.classList.add('hidden'));
        if (defaultTarget && contentSections[defaultTarget]) {
          contentSections[defaultTarget].classList.remove('hidden');
        }
      }
    })();
  </script>
</body>
</html>